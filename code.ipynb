   "id": "a058e272",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('dataset.csv')\n",
    "df.head(2)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8bf031a4",
   "metadata": {},
   "source": [
    "## 2. Identify Inputs (X) and Output (y)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d78e36d3",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_columns = ['tempo', 'duration_ms', 'energy', 'danceability', 'acousticness', 'loudness', 'key', 'liveness', 'valence', 'instrumentalness']\n",
    "y_column = 'popularity'\n",
    "# Preprocessing: Convert selected X columns to numeric, coercing errors to NaN\n",
    "for col in X_columns:\n",
    "    df[col] = pd.to_numeric(df[col], errors='coerce')\n",
    "    # Fill NaN values with the mean of the column\n",
    "    if df[col].isnull().any():\n",
    "        df[col] = df[col].fillna(df[col].mean())\n",
    "\n",
    "X = df[X_columns] # Input\n",
    "y = df[y_column] # Output\n",
    "\n",
    "print(\"Information about X columns after cleaning for Random Forest model:\")\n",
    "X.info()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a51ef0de",
   "metadata": {},
   "source": [
    "## 3. Train the Model\n"
   ]
  },
