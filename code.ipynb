   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6909f2ea",
   "metadata": {},
   "outputs": [],
   "source": [
    "model = RandomForestRegressor()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c6f98e4e",
   "metadata": {},
   "outputs": [],
   "source": [
    "model.fit(X_train,y_train)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f3999711",
   "metadata": {},
   "source": [
    "## 4. Use Model to Predict\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "59314ce1",
   "metadata": {},
   "outputs": [],
   "source": [
    "model.predict(X_test)"
   ]
  },
  {
   "cell_type": "markdown",
